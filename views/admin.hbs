<div class="space-y-8 animate-fade-in-up">
  <!-- Upload Button -->
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white">Library Collection <span id="booksCount"
        class="text-sm font-normal text-neutral-500 ml-2">({{len books}} books)</span></h2>
    <button id="openUploadModal" class="btn-primary inline-flex items-center gap-2">
      <i class="fas fa-plus"></i>
      Upload Books
    </button>
  </div>

  <!-- Book Collection -->
  <div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-4">
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <div class="relative flex-grow sm:w-64">
          <input type="text" id="bookSearch" placeholder="Search books..." class="input-field">
          <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400"></i>
        </div>
        <div class="relative">
          <select id="bookSort" class="input-field appearance-none cursor-pointer pr-10">
            <option value="name-asc" {{#if (or (eq sortMode "" ) (eq sortMode "name-asc" ))}}selected{{/if}}>Name (A-Z)</option>
            <option value="name-desc" {{#if (eq sortMode "name-desc" )}}selected{{/if}}>Name (Z-A)</option>
            <option value="date-desc" {{#if (eq sortMode "date-desc" )}}selected{{/if}}>Newest
              First</option>
            <option value="date-asc" {{#if (eq sortMode "date-asc" )}}selected{{/if}}>Oldest First</option>
          </select>
          <i class="fas fa-sort-amount-down absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400"></i>
          <i
            class="fas fa-chevron-down absolute right-3 top-1/2 -translate-y-1/2 text-neutral-400 pointer-events-none text-xs"></i>
        </div>
      </div>
    </div>

    {{#if books}}
    <div id="booksGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
      {{#each books}}
      {{> admin-book-card this}}
      {{/each}}
    </div>
    {{else}}
    <div class="text-center py-20 rounded-2xl border-dashed border-2">
      <div
        class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-neutral-100 dark:bg-neutral-800 mb-4">
        <i class="fas fa-book-open text-3xl text-neutral-400"></i>
      </div>
      <h3 class="text-lg font-medium text-neutral-900 dark:text-white mb-1">No books yet</h3>
      <p class="text-neutral-500">Upload some books to get started with your library.</p>
    </div>
    {{/if}}
  </div>

  <!-- OPDS Info -->
  <div
    class="theme-card p-6 rounded-xl flex flex-col sm:flex-row items-center justify-between gap-4 bg-gradient-to-r from-neutral-50 to-white dark:from-neutral-800 dark:to-neutral-900">
    <div class="flex items-center space-x-4">
      <div class="p-3 bg-primary-100 dark:bg-primary-900/30 rounded-lg text-primary-600 dark:text-primary-400">
        <i class="fas fa-rss text-xl"></i>
      </div>
      <div>
        <h3 class="font-medium text-neutral-900 dark:text-white">OPDS Feed URL</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">Add this to your reader app. Support sorting with
          <code>?sort=name-asc|date-desc</code>
        </p>
      </div>
    </div>
    <div
      class="flex items-center w-full sm:w-auto bg-white dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-800 rounded-lg p-2 shadow-sm">
      <code id="opdsUrlDisplay"
        class="text-sm text-neutral-600 dark:text-neutral-300 font-mono flex-grow px-2 truncate selection:bg-primary-100">{{baseUrl}}</code>
      <button id="opdsCopyBtn" data-base-url="{{baseUrl}}"
        class="p-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 rounded text-neutral-400 hover:text-primary-600 transition-colors"
        title="Copy URL">
        <i class="far fa-copy"></i>
      </button>
    </div>
  </div>
</div>

<!-- Rename Modal -->
<div id="renameModal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden animate-fade-in">
  <div
    class="bg-white dark:bg-neutral-800 rounded-xl shadow-2xl p-6 w-full max-w-md transform transition-all scale-100">
    <h3 class="text-xl font-bold mb-4 text-neutral-900 dark:text-white">Rename Book</h3>
    <form action="/book/rename" method="post" id="renameForm">
      <input type="hidden" id="oldFilename" name="oldFilename" value="">
      <div class="space-y-4">
        <div>
          <label for="newFilename" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Book
            Name</label>
          <div class="flex rounded-md shadow-sm">
            <input type="text" id="newFilename" name="newFilename" required
              class="input-field flex-1 min-w-0 rounded-r-none">
            <span id="fileExtension"
              class="inline-flex items-center px-3 rounded-r-lg border border-l-0 border-neutral-300 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 text-sm">
              .ext
            </span>
          </div>
        </div>
        <div class="flex justify-end space-x-3 pt-2">
          <button type="button" onclick="closeRenameModal()"
            class="px-4 py-2 rounded-lg text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
            Cancel
          </button>
          <button type="submit"
            class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-500/30">
            Save Changes
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Upload Modal -->
<div id="uploadModal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden animate-fade-in">
  <div
    class="bg-white dark:bg-neutral-800 rounded-xl shadow-2xl p-8 w-full max-w-2xl transform transition-all scale-100">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white">Upload Books</h3>
      <button onclick="closeUploadModal()"
        class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition-colors">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>

    <form action="/book/upload" method="post" enctype="multipart/form-data" id="uploadForm">
      <div id="dropZone"
        class="group cursor-pointer rounded-2xl border-2 border-dashed border-neutral-300 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800/50 py-16 px-6 transition-all duration-300 hover:border-primary-500 hover:bg-primary-50 dark:hover:bg-primary-900/10 dark:hover:border-primary-500">
        <div class="flex flex-col items-center space-y-4">
          <div
            class="p-4 bg-white dark:bg-neutral-800 rounded-full shadow-sm group-hover:scale-110 group-hover:text-primary-600 transition-all duration-300">
            <i
              class="fas fa-cloud-upload-alt text-4xl text-neutral-400 group-hover:text-primary-600 dark:text-neutral-500"></i>
          </div>
          <div class="space-y-2 text-center">
            <h3 class="text-lg font-semibold text-neutral-900 dark:text-white">Drag & Drop files here</h3>
            <p class="text-sm text-neutral-500 dark:text-neutral-400">
              or click to browse
            </p>
            <p class="text-xs text-neutral-400 dark:text-neutral-500 mt-2">
              Support for EPUB, PDF, FB2, MOBI, AZW, CBZ, CBR, DJVU, RTF, TXT
            </p>
          </div>
          <div id="fileInfo"
            class="hidden mt-4 text-sm font-medium text-primary-600 bg-primary-50 dark:bg-primary-900/20 px-4 py-2 rounded-full animate-fade-in">
          </div>
        </div>
      </div>
      <input type="file" id="book" name="book" multiple
        accept=".epub,.pdf,.fb2,.fb2.zip,.cbz,.cbr,.cb7,.mobi,.azw,.azw3,.azw4,.djvu,.txt,.rtf,.html,.htm"
        class="hidden" />
      <div class="flex justify-end space-x-3 pt-6">
        <button type="button" onclick="closeUploadModal()"
          class="px-4 py-2 rounded-lg text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
          Cancel
        </button>
        <button type="submit" id="uploadSubmitBtn" disabled
          class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-500/30 disabled:opacity-50 disabled:cursor-not-allowed">
          Upload
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Book Details Modal -->
<div id="bookDetailsModal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden animate-fade-in">
  <div
    class="bg-white dark:bg-neutral-800 rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden transform transition-all scale-100 flex flex-col">
    <div class="flex justify-between items-center p-6 border-b border-neutral-200 dark:border-neutral-700">
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white">Book Details</h3>
      <button onclick="closeBookDetailsModal()"
        class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition-colors">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>
    <div id="bookDetailsContent" class="flex-1 overflow-y-auto p-6">
      <!-- Content loaded dynamically -->
    </div>
  </div>
</div>

<!-- Edit Metadata Modal -->
<div id="editMetadataModal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden animate-fade-in">
  <div
    class="bg-white dark:bg-neutral-800 rounded-xl shadow-2xl p-6 w-full max-w-2xl transform transition-all scale-100 max-h-[90vh] overflow-y-auto">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-xl font-bold text-neutral-900 dark:text-white">Edit Metadata</h3>
      <button onclick="closeEditMetadataModal()"
        class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition-colors">
        <i class="fas fa-times text-xl"></i>
      </button>
    </div>

    <form action="/book/metadata" method="post" id="editMetadataForm">
      <input type="hidden" id="editFilename" name="filename" value="">
      
      <div class="space-y-4">
        <div>
          <label for="editTitle" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Title</label>
          <input type="text" id="editTitle" name="title" required
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editAuthor" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Author</label>
          <input type="text" id="editAuthor" name="author"
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editDescription" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Description</label>
          <div class="border border-neutral-300 dark:border-neutral-600 rounded-lg overflow-hidden">
            <div class="bg-neutral-100 dark:bg-neutral-800 border-b border-neutral-300 dark:border-neutral-600 p-2 flex gap-1 flex-wrap">
              <button type="button" onclick="formatDoc('bold')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Bold">
                <i class="fas fa-bold"></i>
              </button>
              <button type="button" onclick="formatDoc('italic')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Italic">
                <i class="fas fa-italic"></i>
              </button>
              <button type="button" onclick="formatDoc('underline')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Underline">
                <i class="fas fa-underline"></i>
              </button>
              <div class="w-px bg-neutral-300 dark:bg-neutral-600 mx-1"></div>
              <button type="button" onclick="formatDoc('formatBlock', 'p')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Paragraph">
                <i class="fas fa-paragraph"></i>
              </button>
              <button type="button" onclick="formatDoc('formatBlock', 'h3')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Heading">
                <i class="fas fa-heading"></i>
              </button>
              <div class="w-px bg-neutral-300 dark:bg-neutral-600 mx-1"></div>
              <button type="button" onclick="formatDoc('removeFormat')" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded" title="Clear Formatting">
                <i class="fas fa-eraser"></i>
              </button>
              <button type="button" onclick="toggleSourceView()" class="p-2 hover:bg-neutral-200 dark:hover:bg-neutral-700 rounded ml-auto" title="View Source">
                <i class="fas fa-code"></i>
              </button>
            </div>
            <div id="editDescriptionEditor" contenteditable="true" class="bg-white dark:bg-neutral-900 min-h-[200px] p-3 focus:outline-none prose dark:prose-invert max-w-none text-neutral-900 dark:text-neutral-100"></div>
            <textarea id="editDescriptionSource" class="hidden bg-neutral-900 text-green-400 font-mono text-sm p-3 w-full min-h-[200px] focus:outline-none"></textarea>
          </div>
          <textarea id="editDescription" name="description" rows="4" class="hidden"></textarea>
        </div>
        
        <div>
          <label for="editPublisher" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Publisher</label>
          <input type="text" id="editPublisher" name="publisher"
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editLanguage" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Language</label>
          <input type="text" id="editLanguage" name="language"
            class="input-field w-full" placeholder="e.g., en, es, fr">
        </div>
        
        <div>
          <label for="editIdentifier" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Identifier / ISBN</label>
          <input type="text" id="editIdentifier" name="identifier"
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editSubject" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Subject / Genre</label>
          <input type="text" id="editSubject" name="subject"
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editSeries" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Series</label>
          <input type="text" id="editSeries" name="series"
            class="input-field w-full">
        </div>
        
        <div>
          <label for="editSeriesIndex" class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1">Series Index</label>
          <input type="text" id="editSeriesIndex" name="seriesIndex"
            class="input-field w-full" placeholder="e.g., 1, 2, 3">
        </div>
      </div>
      
      <div class="flex justify-end space-x-3 pt-6">
        <button type="button" onclick="closeEditMetadataModal()"
          class="px-4 py-2 rounded-lg text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
          Cancel
        </button>
        <button type="submit"
          class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors shadow-lg shadow-primary-500/30">
          Save Changes
        </button>
      </div>
    </form>
  </div>
</div>
<script data-total-books="{{len books}}">
  document.addEventListener("DOMContentLoaded", () => {
    const dropZone = document.getElementById("dropZone");
    const fileInput = document.getElementById("book");
    const fileInfo = document.getElementById("fileInfo");
    const uploadSubmitBtn = document.getElementById("uploadSubmitBtn");
    const uploadModal = document.getElementById("uploadModal");
    const openUploadModalBtn = document.getElementById("openUploadModal");

    // Open upload modal
    if (openUploadModalBtn) {
      openUploadModalBtn.addEventListener("click", () => {
        uploadModal.classList.remove("hidden");
      });
    }

    // Close upload modal
    function closeUploadModal() {
      uploadModal.classList.add("hidden");
      fileInput.value = "";
      fileInfo.classList.add("hidden");
      uploadSubmitBtn.disabled = true;
    }

    window.closeUploadModal = closeUploadModal;

    // Close modal on click outside
    uploadModal.addEventListener("click", (e) => {
      if (e.target === uploadModal) {
        closeUploadModal();
      }
    });

    // Drag and drop handlers
    ["dragenter", "dragover", "dragleave", "drop"].forEach((evt) => {
      dropZone.addEventListener(evt, (e) => {
        e.preventDefault();
        e.stopPropagation();
      });
    });

    dropZone.addEventListener("dragover", () => {
      dropZone.classList.add("border-primary-500", "bg-primary-50", "dark:bg-primary-900/10");
    });
    dropZone.addEventListener("dragleave", () => {
      dropZone.classList.remove("border-primary-500", "bg-primary-50", "dark:bg-primary-900/10");
    });

    dropZone.addEventListener("drop", (e) => {
      dropZone.classList.remove("border-primary-500", "bg-primary-50", "dark:bg-primary-900/10");
      const files = e.dataTransfer.files;
      if (files.length === 0) return;

      const validTypes = [
        "application/pdf",
        "application/epub+zip",
        "application/x-fictionbook+xml",
        "application/zip",
        "application/x-cbz",
        "application/vnd.comicbook+zip",
        "application/x-cbr",
        "application/x-mobi",
        "application/x-mobipocket-ebook",
        "application/vnd.amazon.ebook",
        "image/vnd.djvu",
        "text/plain",
        "text/rtf",
        "application/rtf",
        "text/html"
      ];
      // Regex fallback for files with missing/generic mime
      const extRegex = /\.(epub|pdf|fb2|fb2\.zip|cbz|cbr|cb7|mobi|azw|azw3|azw4|djvu|txt|rtf|html|htm)$/i;

      // Validate all files
      let validCount = 0;
      for (const file of files) {
        if (validTypes.includes(file.type) || extRegex.test(file.name)) {
          validCount++;
        }
      }

      if (validCount === 0) {
        fileInfo.classList.remove("hidden", "bg-primary-50", "text-primary-600");
        fileInfo.classList.add("text-red-600", "bg-red-50");
        fileInfo.textContent = "Invalid format. Supported: EPUB, PDF, FB2, MOBI, AZW, CBZ, CBR, DJVU, TXT, RTF";
        return;
      }

      fileInput.files = files;
      fileInfo.classList.remove("hidden", "text-red-600", "bg-red-50");
      fileInfo.classList.add("bg-primary-50", "text-primary-600");
      fileInfo.textContent = `${validCount} file${validCount > 1 ? 's' : ''} selected`;
      uploadSubmitBtn.disabled = false;
    });

    dropZone.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", () => {
      const files = fileInput.files;
      if (files && files.length > 0) {
        fileInfo.classList.remove("hidden", "text-red-600", "bg-red-50");
        fileInfo.classList.add("bg-primary-50", "text-primary-600");
        fileInfo.textContent = `${files.length} file${files.length > 1 ? 's' : ''} selected`;
        uploadSubmitBtn.disabled = false;
      }
    });

    // Form submission
    document.getElementById("uploadForm").addEventListener("submit", () => {
      fileInfo.textContent = "Uploading...";
      uploadSubmitBtn.disabled = true;
    });

  });

  // Rename Modal Logic
  function openRenameModal(filename) {
    const modal = document.getElementById('renameModal');
    const oldInput = document.getElementById('oldFilename');
    const newInput = document.getElementById('newFilename');
    const extSpan = document.getElementById('fileExtension');

    oldInput.value = filename;

    const basename = filename.split('/').pop().split('\\').pop();
    const lastDotIndex = basename.lastIndexOf('.');
    if (lastDotIndex > 0) {
      newInput.value = basename.substring(0, lastDotIndex);
      extSpan.textContent = basename.substring(lastDotIndex);
    } else {
      newInput.value = filename;
      extSpan.textContent = "";
    }

    modal.classList.remove('hidden');
    newInput.focus();
    newInput.select();
  }

  function closeRenameModal() {
    const modal = document.getElementById('renameModal');
    modal.classList.add('hidden');
  }

  // Close modal on click outside
  document.getElementById('renameModal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('renameModal')) {
      closeRenameModal();
    }
  });

  // Search and Sort functionality
  const searchInput = document.getElementById('bookSearch');
  const sortSelect = document.getElementById('bookSort');
  const booksGrid = document.getElementById('booksGrid');
  const booksCount = document.getElementById('booksCount');
  const totalBooks = parseInt(document.currentScript.dataset.totalBooks, 10) || 0;

  // Book card context menu handlers
  document.querySelectorAll('.book-card').forEach(card => {
    const menuBtn = card.querySelector('.book-menu-btn');
    const contextMenu = card.querySelector('.book-context-menu');
    const editMetadataBtn = card.querySelector('.book-edit-metadata');
    const deleteForm = card.querySelector('.book-delete-form');
    const viewDetailsBtn = card.querySelector('.book-view-details');
    const filename = card.dataset.filename;

    if (menuBtn && contextMenu) {
      menuBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        // Close all other menus
        document.querySelectorAll('.book-context-menu').forEach(menu => {
          if (menu !== contextMenu) menu.classList.add('hidden');
        });
        
        contextMenu.classList.toggle('hidden');
      });

      // Close menu when clicking outside
      document.addEventListener('click', (e) => {
        if (!contextMenu.contains(e.target) && !menuBtn.contains(e.target)) {
          contextMenu.classList.add('hidden');
        }
      });
    }

    if (editMetadataBtn && filename) {
      editMetadataBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        contextMenu.classList.add('hidden');
        openEditMetadataModal(filename);
      });
    }

    if (deleteForm && filename) {
      deleteForm.addEventListener('submit', (e) => {
        const title = card.dataset.title || 'this book';
        if (!confirm(`Delete ${title}?`)) {
          e.preventDefault();
        }
      });
    }

    if (viewDetailsBtn && filename) {
      viewDetailsBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        openBookDetailsModal(filename);
      });
    }
  });

  // Book details modal
  const bookDetailsModal = document.getElementById('bookDetailsModal');
  const bookDetailsContent = document.getElementById('bookDetailsContent');

  async function openBookDetailsModal(filename) {
    bookDetailsContent.innerHTML = '<div class="flex items-center justify-center h-full"><i class="fas fa-spinner fa-spin text-2xl text-primary-600"></i></div>';
    bookDetailsModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    try {
      const response = await fetch(`/book/info/${filename}`);
      if (response.ok) {
        const html = await response.text();
        // Extract the content from the full page (remove the outer wrapper)
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');
        const content = doc.querySelector('.bg-white.dark\\:bg-neutral-800');
        if (content) {
          bookDetailsContent.innerHTML = content.innerHTML;
        } else {
          bookDetailsContent.innerHTML = '<p class="text-red-600">Failed to load book details</p>';
        }
      } else {
        bookDetailsContent.innerHTML = '<p class="text-red-600">Failed to load book details</p>';
      }
    } catch (error) {
      console.error('Error loading book details:', error);
      bookDetailsContent.innerHTML = '<p class="text-red-600">Failed to load book details</p>';
    }
  }

  function closeBookDetailsModal() {
    bookDetailsModal.classList.add('hidden');
    document.body.style.overflow = '';
    bookDetailsContent.innerHTML = '';
  }

  window.closeBookDetailsModal = closeBookDetailsModal;

  // Close modal on click outside
  bookDetailsModal.addEventListener('click', (e) => {
    if (e.target === bookDetailsModal) {
      closeBookDetailsModal();
    }
  });

  // Close modal on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !bookDetailsModal.classList.contains('hidden')) {
      closeBookDetailsModal();
    }
    if (e.key === 'Escape' && !editMetadataModal.classList.contains('hidden')) {
      closeEditMetadataModal();
    }
  });

  // Edit metadata modal
  const editMetadataModal = document.getElementById('editMetadataModal');
  const editMetadataForm = document.getElementById('editMetadataForm');
  const editDescriptionEditor = document.getElementById('editDescriptionEditor');
  const editDescriptionSource = document.getElementById('editDescriptionSource');
  const editDescription = document.getElementById('editDescription');
  let isSourceView = false;

  // Rich text editor functions
  window.formatDoc = function(cmd, value = null) {
    if (isSourceView) return;
    document.execCommand(cmd, false, value);
    editDescriptionEditor.focus();
  };

  window.toggleSourceView = function() {
    isSourceView = !isSourceView;
    if (isSourceView) {
      editDescriptionSource.value = editDescriptionEditor.innerHTML;
      editDescriptionEditor.classList.add('hidden');
      editDescriptionSource.classList.remove('hidden');
    } else {
      editDescriptionEditor.innerHTML = editDescriptionSource.value;
      editDescriptionEditor.classList.remove('hidden');
      editDescriptionSource.classList.add('hidden');
    }
  };

  async function openEditMetadataModal(filename) {
    const card = document.querySelector(`.book-card[data-filename="${filename}"]`);
    if (!card) return;

    // Populate form with current metadata
    document.getElementById('editFilename').value = filename;
    document.getElementById('editTitle').value = card.dataset.title || '';
    document.getElementById('editAuthor').value = card.dataset.author || '';
    
    // Handle description HTML
    const description = card.dataset.description || '';
    editDescriptionEditor.innerHTML = description;
    editDescriptionSource.value = description;
    editDescription.value = description;
    
    document.getElementById('editPublisher').value = card.dataset.publisher || '';
    document.getElementById('editLanguage').value = card.dataset.language || '';
    document.getElementById('editIdentifier').value = card.dataset.identifier || '';
    document.getElementById('editSubject').value = card.dataset.subject || '';
    document.getElementById('editSeries').value = card.dataset.series || '';
    document.getElementById('editSeriesIndex').value = card.dataset.seriesIndex || '';

    // Reset to WYSIWYG view
    isSourceView = false;
    editDescriptionEditor.classList.remove('hidden');
    editDescriptionSource.classList.add('hidden');

    editMetadataModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeEditMetadataModal() {
    editMetadataModal.classList.add('hidden');
    document.body.style.overflow = '';
    editMetadataForm.reset();
  }

  window.closeEditMetadataModal = closeEditMetadataModal;

  // Close modal on click outside
  editMetadataModal.addEventListener('click', (e) => {
    if (e.target === editMetadataModal) {
      closeEditMetadataModal();
    }
  });

  // Handle form submission
  editMetadataForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Sync editor content to hidden textarea
    if (isSourceView) {
      editDescription.value = editDescriptionSource.value;
    } else {
      editDescription.value = editDescriptionEditor.innerHTML;
    }
    
    const formData = new FormData(editMetadataForm);
    
    try {
      const response = await fetch('/book/metadata', {
        method: 'POST',
        body: formData
      });
      
      if (response.ok) {
        closeEditMetadataModal();
        // Reload page to show updated metadata
        window.location.reload();
      } else {
        alert('Failed to update metadata');
      }
    } catch (error) {
      console.error('Error updating metadata:', error);
      alert('Failed to update metadata');
    }
  });

  function filterAndSortBooks() {
    if (!booksGrid) return;

    const query = searchInput.value.toLowerCase().trim();
    const sortMode = sortSelect.value;
    const bookCards = Array.from(booksGrid.querySelectorAll('.book-card'));
    let visibleCount = 0;

    // Filter
    bookCards.forEach(card => {
      const title = (card.dataset.title || '').toLowerCase();
      const author = (card.dataset.author || '').toLowerCase();
      const subject = (card.dataset.subject || '').toLowerCase();
      const series = (card.dataset.series || '').toLowerCase();
      
      if (title.includes(query) || author.includes(query) || subject.includes(query) || series.includes(query)) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Sort
    bookCards.sort((a, b) => {
      if (sortMode === 'name-asc') {
        return a.dataset.title.localeCompare(b.dataset.title);
      } else if (sortMode === 'name-desc') {
        return b.dataset.title.localeCompare(a.dataset.title);
      } else if (sortMode === 'date-desc') {
        return (new Date(b.dataset.added).getTime()) - (new Date(a.dataset.added).getTime());
      } else if (sortMode === 'date-asc') {
        return (new Date(a.dataset.added).getTime()) - (new Date(b.dataset.added).getTime());
      }
      return 0;
    });

    // Reorder DOM
    bookCards.forEach(card => booksGrid.appendChild(card));

    // Update count
    if (booksCount) {
      if (query) {
        booksCount.textContent = `(${visibleCount} of ${totalBooks} books)`;
      } else {
        booksCount.textContent = `(${totalBooks} books)`;
      }
    }
  }

  const opdsUrlDisplay = document.getElementById('opdsUrlDisplay');
  const opdsCopyBtn = document.getElementById('opdsCopyBtn');

  function updateOpdsUrl() {
    if (!opdsUrlDisplay || !opdsCopyBtn || !sortSelect) return;
    const baseUrl = opdsCopyBtn.dataset.baseUrl;
    const sortMode = sortSelect.value;
    const fullUrl = `${baseUrl}/?sort=${sortMode}`;
    opdsUrlDisplay.textContent = fullUrl;
  }

  if (opdsCopyBtn) {
    opdsCopyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(opdsUrlDisplay.textContent);
      const icon = opdsCopyBtn.querySelector('i');
      icon.classList.replace('far', 'fas');
      icon.classList.replace('fa-copy', 'fa-check');
      setTimeout(() => {
        icon.classList.replace('fas', 'far');
        icon.classList.replace('fa-check', 'fa-copy');
      }, 2000);
    });
  }

  if (searchInput && sortSelect && booksGrid) {
    searchInput.addEventListener('input', filterAndSortBooks);
    sortSelect.addEventListener('change', () => {
      filterAndSortBooks();
      updateOpdsUrl();
      // Update URL without reloading to persist sort choice on refresh
      const url = new URL(window.location);
      url.searchParams.set('sort', sortSelect.value);
      window.history.pushState({}, '', url);
    });

    // Initial sort and URL setup
    filterAndSortBooks();
    updateOpdsUrl();
  }
</script>
