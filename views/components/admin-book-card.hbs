<div data-title="{{title}}" data-added="{{lastUpdated}}" data-filename="{{filename}}"
  data-author="{{author}}" data-description="{{description}}" data-publisher="{{publisher}}"
  data-language="{{language}}" data-identifier="{{identifier}}" data-subject="{{subject}}"
  data-series="{{series}}" data-series-index="{{seriesIndex}}"
  class="book-card dark:bg-dark-card bg-light-card group relative overflow-hidden hover:shadow-lg flex flex-col h-full focus:outline-none rounded-lg cursor-pointer"
  tabindex="0">

  <!-- Cover Image -->
  <div class="aspect-[2/3] relative overflow-hidden bg-neutral-100 dark:bg-neutral-800">
    <button class="book-view-details block w-full h-full" data-filename="{{filename}}">
      <img src="/book/cover/{{filename}}" class="w-full h-full object-cover transition-transform group-hover:scale-105" alt="{{title}}"
        loading="lazy" onerror="this.onerror=null;this.src='/static/no-cover-error.svg';">
    </button>

    <!-- Menu Button -->
    <button class="book-menu-btn absolute top-2 right-2 p-2 bg-black/50 hover:bg-black/70 rounded-full text-white opacity-0 group-hover:opacity-100 transition-opacity z-10"
      title="More options">
      <i class="fas fa-ellipsis-v"></i>
    </button>

    <!-- Context Menu -->
    <div class="book-context-menu absolute top-10 right-2 bg-white dark:bg-neutral-800 rounded-lg shadow-lg hidden z-20 min-w-[150px]">
      <button class="book-edit-metadata w-full text-left px-4 py-2 text-sm text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 flex items-center gap-2"
        title="Edit Metadata">
        <i class="fas fa-edit"></i>
        Edit Metadata
      </button>
      <form action="/book/delete/{{filename}}" method="post" class="book-delete-form">
        <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 flex items-center gap-2"
          title="Delete">
          <i class="fas fa-trash-alt"></i>
          Delete
        </button>
      </form>
    </div>
  </div>

  <!-- Content -->
  <div class="px-4 py-2 flex flex-col flex-grow">
    <h3 class="font-semibold text-neutral-900 dark:text-white text-sm line-clamp-2 mb-2 leading-tight"
      title="{{title}}">{{title}}</h3>
    <div
      class="mt-auto flex items-center justify-between text-xs font-medium text-neutral-500 dark:text-neutral-400">
      <span class="px-2 py-1 rounded bg-neutral-100 dark:bg-neutral-700 text-neutral-700 dark:text-neutral-300">
        {{simpleMime mimeType}}
      </span>
      <span>{{formatSize size}}</span>
    </div>
  </div>
</div>
